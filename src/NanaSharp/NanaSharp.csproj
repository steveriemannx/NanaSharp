<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>Nana</RootNamespace>
    <AssemblyName>NanaSharp</AssemblyName>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Description>C# bindings for the Nana C++ GUI library. Supports Linux, FreeBSD, macOS, and Windows.</Description>
    <Version>0.1.0</Version>
    <Authors>NanaSharp Contributors</Authors>
    <PackageLicenseExpression>BSL-1.0</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Runtime.InteropServices" Version="4.3.0" />
  </ItemGroup>

</Project>
